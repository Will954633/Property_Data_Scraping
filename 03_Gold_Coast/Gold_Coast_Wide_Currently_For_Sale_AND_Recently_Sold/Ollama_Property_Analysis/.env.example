# Last Edit: 31/01/2026, Friday, 7:43 pm (Brisbane Time)
# Environment variables for Ollama Property Analysis System
# Copy this file to .env and update with your values

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/
# Database and collection are set in config.py for Gold_Coast_Currently_For_Sale

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=300

# Processing Configuration
MAX_RETRIES=3
RETRY_DELAY=5
REQUEST_TIMEOUT=300

# Image Processing
MAX_IMAGES_PER_PROPERTY=30

# Logging
LOG_LEVEL=INFO

# Parallel Processing
NUM_WORKERS=2
PARALLEL_BATCH_SIZE=50
WORKER_HEARTBEAT_INTERVAL=60
WORKER_TIMEOUT=600
ENABLE_WORKER_LOGS=True
ENABLE_PROGRESS_LOG=True

# Testing Configuration
TEST_RUN=True
MAX_BATCHES=2
