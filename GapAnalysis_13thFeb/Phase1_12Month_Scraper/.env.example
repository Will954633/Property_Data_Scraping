# Azure Cosmos DB Connection String
# Replace with your actual connection string from Azure Portal
COSMOS_CONNECTION_STRING="mongodb://your-cosmos-account:your-key@your-cosmos-account.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@your-cosmos-account@"

# Alternative: Local MongoDB for testing
# COSMOS_CONNECTION_STRING="mongodb://127.0.0.1:27017/"
